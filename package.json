{
  "name": "knit-mcp",
  "version": "0.14.1",
  "description": "Knit — second brain for any MCP-speaking AI coding agent (Claude Code, Cursor, Codex CLI, Cline, Continue, GitHub Copilot). Per-project memory, tier-routed workflow protocol, parallel team worktrees.",
  "type": "module",
  "bin": {
    "knit": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --dts --clean && npm run vendor-agents && npm run build:webapp",
    "build:webapp": "cd webapp && (npm install --prefer-offline --no-audit --no-fund || npm install) && npm run build",
    "vendor-agents": "node scripts/vendor-agents.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "npm run bench:retrieval",
    "bench:retrieval": "tsx benchmarks/retrieval-synthetic.ts",
    "bench:tokens": "tsx benchmarks/token-economy.ts",
    "bench:all": "npm run bench:retrieval && npm run bench:tokens",
    "check:leaks": "node scripts/check-leaks.mjs",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run bench && npm run check:leaks && npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "memory",
    "workflow",
    "claude-code",
    "mcp",
    "mcp-server",
    "second-brain",
    "developer-tools",
    "knit"
  ],
  "author": "Piyush Dua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PDgit12/knit.git"
  },
  "homepage": "https://github.com/PDgit12/knit",
  "bugs": {
    "url": "https://github.com/PDgit12/knit/issues"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    }
  },
  "files": [
    "dist",
    "webapp/dist",
    "webapp/index.html",
    "THIRD-PARTY-NOTICES.md"
  ]
}
